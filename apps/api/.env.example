# Database
DATABASE_URL=postgresql://pichichi:pichichi_dev@localhost:5432/pichichi?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=30d

# OAuth — Google
# Must be the **Web** Client ID from Google Cloud Console.
# The backend uses this to verify ID tokens via google-auth-library.
# Mobile ID tokens carry the Web Client ID as their `aud` claim
# (set via EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID on the mobile side).
GOOGLE_CLIENT_ID=

# OAuth — Apple
APPLE_CLIENT_ID=

# App
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# Firebase (Push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# API-Football (tournament data import)
# Get your key at https://dashboard.api-football.com
API_FOOTBALL_KEY=

# Match Sync (automatic score updates)
# Set to 'true' to enable automatic match score syncing from API-Football.
# Requires API_FOOTBALL_KEY to be set. When 'false' or unset, sync is disabled.
SYNC_ENABLED=false
