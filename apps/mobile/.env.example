# Copy this file to .env and fill in the values.
# Expo automatically loads .env files — no dotenv import needed.

# API URL — use localhost for development (Android emulator auto-resolves to 10.0.2.2)
# Physical device:  use http://<your-local-ip>:3000/api/v1
# Production:       use https://api.yourdomain.com/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Must match backend GOOGLE_CLIENT_ID (Web Client ID from Google Cloud Console).
# This ensures the idToken audience matches what the backend expects for verification.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
