{
  "name": "pichichi",
  "version": "0.1.0",
  "private": true,
  "description": "Pichichi — Tournament prediction platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "npm run dev -w apps/api",
    "api:build": "npm run build -w apps/api",
    "web:dev": "npm run dev -w apps/web",
    "web:build": "npm run build -w apps/web",
    "prisma:generate": "npx prisma generate --schema=apps/api/prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=apps/api/prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=apps/api/prisma/schema.prisma",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "icons:gen": "node scripts/generate-icons.mjs"
  },
  "devDependencies": {
    "opentype.js": "^1.3.4",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.5"
  },
  "overrides": {
    "react-native-worklets": "0.7.2"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@react-native-community/netinfo": "11.5.2"
  }
}
